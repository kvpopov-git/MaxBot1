# Токен из карточки бота: https://dev.max.ru/docs/chatbots/bots-nocode/manage
BOT_TOKEN=

# Числовой chat_id канала, куда публиковать отложенные посты (бот должен быть админом канала)
CHANNEL_ID=

# user_id пользователей, которым разрешено планировать посты (через запятую). Узнать id: команда /my_id
ADMIN_USER_IDS=

# Обработка изображений для --img (опционально)
# IMAGE_MAX_WIDTH=1920
# IMAGE_MAX_HEIGHT=2560
# JPEG_QUALITY=85
